{
  "name": "orbitumd",
  "private": true,
  "version": "0.1.0",
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "scripts": {
    "postinstall": "npm --prefix site install",
    "dev": "npm --prefix site run dev --",
    "build": "npm --prefix site run build --",
    "preview": "npm --prefix site run preview --",
    "lint": "npm --prefix site run lint --",
    "test": "npm --prefix site run test --",
    "scrape:requirements": "node catalog-scraper/scrape_umd_requirements.js",
    "corpus:requirements": "npx ts-node scripts/generateRequirementRegressionCorpus.ts",
    "corpus:requirements:strict": "npx ts-node scripts/generateRequirementRegressionCorpus.ts --strict-fallback-mode --min-quality-score 0.25",
    "corpus:verify": "npx ts-node scripts/verifyRequirementCorpusBaseline.ts",
    "ingest:requirements": "npx ts-node scripts/ingestAllPrograms.ts",
    "sync:catalog": "node data-sync/sync-worker.mjs",
    "sync:catalog:dry": "node data-sync/sync-worker.mjs --dry-run=true"
  }
}
